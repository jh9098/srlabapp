APP_NAME=지지저항Lab Backend API
APP_ENV=dev
APP_DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# PostgreSQL 권장. 로컬 개발에서는 sqlite 로 시작 가능.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/srlab

# 앱/관리자 서명 시크릿
SECRET_KEY=replace-with-app-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-admin-password
ADMIN_JWT_SECRET=replace-with-admin-jwt-secret
ADMIN_JWT_ALGORITHM=HS256
ADMIN_TOKEN_EXPIRE_MINUTES=480

# CORS: 쉼표(,)로 구분합니다.
CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:3000,http://localhost:3000
# 필요 없으면 비워도 됩니다.
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Runtime feature flags
SCHEDULER_ENABLED=false
SIGNAL_BATCH_ENABLED=true
PUSH_ENABLED=false

# FCM / Push (선택)
FCM_ENABLED=false
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVICE_ACCOUNT_FILE=
FCM_PROJECT_ID=
FCM_SERVER_KEY=
